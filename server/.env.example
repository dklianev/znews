# MongoDB Atlas connection string
# Replace with your actual connection string from MongoDB Atlas
MONGODB_URI=mongodb+srv://zemun_admin:YOUR_PASSWORD@zemun-news.xxxxx.mongodb.net/zemun-news?retryWrites=true&w=majority

# Server port
PORT=3001

# JWT secret (32+ chars in production)
JWT_SECRET=change-me-to-a-long-random-secret
REFRESH_TOKEN_SECRET=change-me-to-a-different-long-random-secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=14

# Allowed web origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Seeded admin password (required in production)
DEFAULT_ADMIN_PASSWORD=change-me-to-a-strong-password

# Public canonical base URL (used in share/meta URLs)
PUBLIC_BASE_URL=https://znews.live

# File storage driver: disk | spaces
STORAGE_DRIVER=disk

# DigitalOcean Spaces (required when STORAGE_DRIVER=spaces)
SPACES_BUCKET=your-space-name
SPACES_REGION=nyc3
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_KEY=your-spaces-access-key
SPACES_SECRET=your-spaces-secret-key
SPACES_PUBLIC_BASE_URL=https://your-space-name.nyc3.cdn.digitaloceanspaces.com
# Optional ACL for uploaded objects (set empty to skip ACL)
SPACES_OBJECT_ACL=public-read

# Optional extra blocked terms for public comments (comma-separated)
BLOCKED_COMMENT_TERMS=discord.gg,http://,https://

# Optional dedupe windows (milliseconds)
POLL_VOTE_WINDOW_MS=86400000
ARTICLE_VIEW_WINDOW_MS=21600000
