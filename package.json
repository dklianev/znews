{
  "name": "zemun-news",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "smoke:safe": "node scripts/smoke-safe.mjs",
    "audit:motion": "node scripts/audit-motion.mjs",
    "audit:perf": "node scripts/audit-performance.mjs",
    "check:server": "node --check server/index.js && node --check server/app.js && node --check server/seed.js && node --check server/gameSeed.js && node --check server/scripts/seed-games-next-month.js && node --check server/scripts/backfill-image-pipeline.js && node --check server/scripts/migrate-local-uploads-to-spaces.js && node --check server/scripts/migrate-ads-to-slots.js && node --check server/scripts/audit-article-dates.js",
    "check": "npm run check:server && npm run build",
    "test": "vitest run --config vitest.config.mjs",
    "test:vitest": "vitest run --config vitest.config.mjs",
    "test:watch": "vitest --config vitest.config.mjs",
    "test:coverage": "vitest run --coverage --config vitest.config.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "seed": "node server/seed.js",
    "seed:games": "node server/scripts/seed-games-next-month.js",
    "images:backfill": "node server/scripts/backfill-image-pipeline.js",
    "storage:migrate-local": "node server/scripts/migrate-local-uploads-to-spaces.js",
    "ads:migrate:dry": "node server/scripts/migrate-ads-to-slots.js",
    "ads:migrate:write": "node server/scripts/migrate-ads-to-slots.js --write",
    "articles:audit-dates": "node server/scripts/audit-article-dates.js",
    "articles:fix-dates": "node server/scripts/audit-article-dates.js --write"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1012.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.7.0",
    "mongoose": "^9.3.1",
    "motion": "^12.38.0",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.6",
    "react-is": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "sharp": "^0.34.5",
    "sqlite3": "^5.1.7",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@csstools/postcss-color-mix-function": "^4.0.2",
    "@csstools/postcss-media-minmax": "^3.0.1",
    "@csstools/postcss-oklab-function": "^5.0.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "docx": "^9.6.1",
    "jsdom": "^29.0.1",
    "mongodb-memory-server": "^11.0.1",
    "postcss": "^8.4.40",
    "postcss-value-parser": "^4.2.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2",
    "workbox-window": "^7.4.0"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  }
}
