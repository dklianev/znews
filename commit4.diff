-        style={{ width: `${readProgress}%` }}
+        ref={progressBarRef}
+        className="fixed top-0 left-0 h-1 w-full bg-gradient-to-r from-zn-hot to-zn-orange z-[100] transition-transform duration-150 ease-out"
