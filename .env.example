# Zemun News — Environment Variables
# Copy this to .env and fill in your values

# MongoDB connection string (leave empty or placeholder for in-memory dev mode)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/zemun-news
# Optional fallback if in-memory MongoDB cannot start (e.g. EPERM on Windows)
DEV_MONGODB_FALLBACK_URI=mongodb://127.0.0.1:27017/zemun-news

# Server port (default: 3001)
PORT=3001
# Enable request rate limiting in development (default: disabled in dev, always enabled in production)
ENABLE_RATE_LIMIT_IN_DEV=false
# Proxy hops to trust for client IP extraction (e.g. 1 on most PaaS). Set true to trust all proxies.
TRUST_PROXY=1
# Global API rate-limit window and caps
# RATE_LIMIT_WINDOW supports values like 15m, 1h, 300000 (ms)
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_READ_MAX=1200
RATE_LIMIT_WRITE_MAX=300

# Admin session secret for JWT (generate a random string)
JWT_SECRET=change-me-to-a-random-secret-string
REFRESH_TOKEN_SECRET=change-me-to-a-different-random-secret-string
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=14

# Default seeded admin password (required in production)
DEFAULT_ADMIN_PASSWORD=change-me-to-a-strong-password

# Frontend URL for CORS (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:3000,https://znews.live
# Public canonical base URL (used in share/meta URLs)
PUBLIC_BASE_URL=https://znews.live

# File storage driver: disk | spaces | azure
STORAGE_DRIVER=disk

# DigitalOcean Spaces (required when STORAGE_DRIVER=spaces)
SPACES_BUCKET=your-space-name
SPACES_REGION=nyc3
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_KEY=your-spaces-access-key
SPACES_SECRET=your-spaces-secret-key
SPACES_PUBLIC_BASE_URL=https://your-space-name.nyc3.cdn.digitaloceanspaces.com
# Optional ACL for uploaded objects (set empty to skip ACL)
SPACES_OBJECT_ACL=public-read

# Azure Blob Storage (required when STORAGE_DRIVER=azure)
# Use either AZURE_BLOB_ENDPOINT or AZURE_BLOB_ACCOUNT
AZURE_BLOB_ACCOUNT=yourstorageaccount
AZURE_BLOB_ENDPOINT=https://yourstorageaccount.blob.core.windows.net
AZURE_BLOB_CONTAINER=uploads
# Container-level SAS token (without leading ?), with create/read/write/list/delete permissions
AZURE_BLOB_SAS_TOKEN=sv=...&ss=...&srt=...&sp=rwdlc...
# Optional public URL base (defaults to AZURE_BLOB_ENDPOINT/AZURE_BLOB_CONTAINER)
AZURE_BLOB_PUBLIC_BASE_URL=https://yourstorageaccount.blob.core.windows.net/uploads
# Optional API version
AZURE_BLOB_API_VERSION=2023-11-03
